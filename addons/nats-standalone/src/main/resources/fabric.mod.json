{
	"schemaVersion": 1,
	"id": "open-economy-nats-standalone",
	"version": "${version}",
	"name": "OpenEconomy NATS Standalone",
	"description": "High-performance unified NATS storage & messaging for OpenEconomy using KV Watchers.",
	"authors": [
		"Savage"
	],
	"contact": {
		"sources": "https://github.com/xSaVageAU/OpenEconomy"
	},
	"license": "CC0-1.0",
	"environment": "*",
	"entrypoints": {
		"main": [
			"savage.openeconomy.nats.standalone.OpenEconomyNatsStandalone"
		],
		"openeconomy:storage": [
			"savage.openeconomy.nats.standalone.storage.NatsStandaloneStorageProvider"
		],
		"openeconomy:messaging": [
			"savage.openeconomy.nats.standalone.messaging.NatsStandaloneMessagingProvider"
		]
	},
	"depends": {
		"fabricloader": ">=0.18.5",
		"minecraft": "~26.1",
		"java": ">=25",
		"open-economy": "*"
	}
}
